{
  "permissions": {
    "allow": [
      "Bash(uv sync:*)",
      "Bash(uv run wtm:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run python:*)",
      "Bash(uv add:*)",
      "Bash(swiftc:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(say:*)",
      "Bash(afconvert:*)",
      "Bash(afplay:*)",
      "Bash(pgrep:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run ruff check src/ 1>&2 || exit 2"
          }
        ]
      }
    ]
  }
}
